rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'yokotenkaizen@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidWord(data) {
      return data.word is string && data.word.size() > 0 && data.word.size() <= 200
          && data.category is string && data.category.size() > 0 && data.category.size() <= 100
          && data.definition is string && data.definition.size() > 0 && data.definition.size() <= 3000
          && data.examples is list && data.examples.size() <= 20;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Words collection
    match /words/{wordId} {
      // Siapa pun bisa membaca dan mencari kata
      allow get: if true;
      allow list: if true;
      
      // NOTE: Permissive rules to support manual admin login bypass requested by user
      allow create, update, delete: if true;
    }

    // Stats collection
    match /stats/{statId} {
      allow get: if true;
      // Memungkinkan update field totalSearches dan totalInstalls oleh siapa pun
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalSearches', 'totalInstalls']);
      // Allow create if it doesn't exist
      allow create: if true;
    }
  }
}
